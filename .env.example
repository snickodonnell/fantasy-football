# Copy to .env later if you want to keep local secrets out of shell history.
PORT=3100
HOST=0.0.0.0
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-string
BACKUP_RETENTION=14
BACKUP_INTERVAL_HOURS=24

# Optional: comma-separated IPs or prefixes allowed to use API routes.
# Example for a typical home network: LAN_ALLOWLIST=192.168.1.,127.0.0.1
LAN_ALLOWLIST=

# balldontlie NFL API docs: https://nfl.balldontlie.io/
# Header expected by the API: Authorization: YOUR_API_KEY
BALLDONTLIE_API_KEY=
SPORTSDATAIO_API_KEY=
